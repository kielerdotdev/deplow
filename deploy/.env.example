# Written/filled by deploy/install.sh — keep secrets out of git.
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:9565
HOSTRIG_PUBLIC_URL=http://localhost:9565
HOSTRIG_SECRETS_KEY=replace-me-long-random

# Seeds Domains on first boot only; change day-to-day in the UI
HOSTRIG_BASE_DOMAIN=apps.localhost
HOSTRIG_PUBLIC_URL_PROTOCOL=http

# Bundled MinIO (default via install.sh + compose profile bundled-s3)
HOSTRIG_S3_PROVIDER=minio
HOSTRIG_S3_ENDPOINT=http://minio:9000
HOSTRIG_S3_APP_ENDPOINT=http://minio:9000
HOSTRIG_S3_ACCESS_KEY=change-me-access-key
HOSTRIG_S3_SECRET_KEY=change-me-long-random-secret
HOSTRIG_S3_REGION=us-east-1
HOSTRIG_BACKUP_BUCKET=hostrig-backups

# Platform Redis (BullMQ) — required; install.sh generates a strong value
HOSTRIG_REDIS_PASSWORD=change-me-redis-password

# After first admin exists, public sign-up is off unless set to 1
# HOSTRIG_ALLOW_SIGNUP=0

# External S3 instead: HOSTRIG_BUNDLE_MINIO=0 and set provider/keys, e.g. R2:
# HOSTRIG_S3_PROVIDER=r2
# HOSTRIG_R2_ACCOUNT_ID=
# HOSTRIG_S3_ACCESS_KEY=
# HOSTRIG_S3_SECRET_KEY=
# HOSTRIG_S3_REGION=auto

HOSTRIG_DOCKER_NETWORK=hostrig_default
HOSTRIG_APP_RUNTIME=runsc
HOSTRIG_APP_RUNTIME_REQUIRED=true
BUILDKIT_HOST=docker-container://buildkit

# Optional Cloudflare Tunnel (compose profile: edge)
# CLOUDFLARE_TUNNEL_TOKEN=

# Pin control-plane image (install.sh also honors HOSTRIG_VERSION)
# HOSTRIG_IMAGE=ghcr.io/kielerdotdev/hostrig:latest
