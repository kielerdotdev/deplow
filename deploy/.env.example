# Written/filled by deploy/install.sh — keep secrets out of git.
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:9565
DEPLOW_PUBLIC_URL=http://localhost:9565
DEPLOW_SECRETS_KEY=replace-me-long-random

# Seeds Domains on first boot only; change day-to-day in the UI
DEPLOW_BASE_DOMAIN=apps.localhost
DEPLOW_PUBLIC_URL_PROTOCOL=http

# Bundled MinIO (default via install.sh + compose profile bundled-s3)
DEPLOW_S3_PROVIDER=minio
DEPLOW_S3_ENDPOINT=http://minio:9000
DEPLOW_S3_APP_ENDPOINT=http://minio:9000
DEPLOW_S3_ACCESS_KEY=deplow
DEPLOW_S3_SECRET_KEY=deplowsecret
DEPLOW_S3_REGION=us-east-1
DEPLOW_BACKUP_BUCKET=deplow-backups

# External S3 instead: DEPLOW_BUNDLE_MINIO=0 and set provider/keys, e.g. R2:
# DEPLOW_S3_PROVIDER=r2
# DEPLOW_R2_ACCOUNT_ID=
# DEPLOW_S3_ACCESS_KEY=
# DEPLOW_S3_SECRET_KEY=
# DEPLOW_S3_REGION=auto

DEPLOW_DOCKER_NETWORK=deplow_default
DEPLOW_APP_RUNTIME=runsc
DEPLOW_APP_RUNTIME_REQUIRED=true
BUILDKIT_HOST=docker-container://buildkit

# Optional Cloudflare Tunnel (compose profile: edge)
# CLOUDFLARE_TUNNEL_TOKEN=

# Pin control-plane image (install.sh also honors DEPLOW_VERSION)
# DEPLOW_IMAGE=ghcr.io/kielerdotdev/deplow:latest
