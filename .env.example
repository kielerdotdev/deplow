# Web / auth
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=data/deplow.db

# Platform object storage (see docker-compose.yml)
# Postgres/Redis are dedicated per-project containers — no shared admin URL required.
DEPLOW_POSTGRES_IMAGE=postgres:16-alpine
DEPLOW_REDIS_IMAGE=redis:7-alpine

# Control-plane Redis for BullMQ job queue (docker compose service: platform-redis)
DEPLOW_QUEUE_REDIS_URL=redis://127.0.0.1:56380
# Set DEPLOW_USE_QUEUE=false to fall back to in-process execution
# DEPLOW_USE_QUEUE=true
DEPLOW_MINIO_ENDPOINT=http://127.0.0.1:59000
DEPLOW_MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:59000
DEPLOW_MINIO_ACCESS_KEY=deplow
DEPLOW_MINIO_SECRET_KEY=deplowsecret
DEPLOW_BACKUP_BUCKET=deplow-backups
# Daily schedule; set DEPLOW_BACKUP_ALLOW_FAST=1 only for local demos under 1h
# DEPLOW_BACKUP_DEFAULT_INTERVAL_MS=86400000
# DEPLOW_BACKUP_RETAIN=7
# PITR per project Postgres (pgBackRest stanza = project id — see docs/guides/backups)
DEPLOW_PITR_ENABLED=1
# Absolute path recommended; used by host `pgbackrest` or dockerized fallback
PGBACKREST_CONFIG=./infra/pgbackrest/pgbackrest.conf
# DEPLOW_PGBACKREST_IMAGE=woblerr/pgbackrest:2.58.0-alpine
DEPLOW_SECRETS_KEY=replace-me-long-random

# Docker network (compose project name + _default)
DEPLOW_DOCKER_NETWORK=deplow_default

# User app runtime (gVisor by default — see docs/secure-runtime.md)
DEPLOW_APP_RUNTIME=runsc
DEPLOW_APP_RUNTIME_REQUIRED=true
# DEPLOW_APP_MEMORY_MB=512
# DEPLOW_APP_CPUS=1
# DEPLOW_APP_READONLY_ROOTFS=true

# Public access: app-managed domains (Domains tab in the app).
# These env vars only seed the DB on first boot; the UI is authoritative after that.
# Prefer a dedicated subzone (apps.example.com) so DEPLOW_PUBLIC_URL can differ.
# Local: apps.localhost + http. Production: set in UI + https + Cloudflare Tunnel.
# All edges forward to http://caddy:80 (compose) or http://127.0.0.1:8088 (host).
DEPLOW_BASE_DOMAIN=apps.localhost
DEPLOW_PUBLIC_URL_PROTOCOL=http
DEPLOW_PROXY_ROUTES_DIR=infra/caddy/routes
# Cloudflare Tunnel token (docker compose --profile edge)
# Zero Trust public hostname: *.apps.example.com → http://caddy:80
CLOUDFLARE_TUNNEL_TOKEN=

# Git webhook deploys + OAuth (see docs/git-oauth.md)
DEPLOW_GIT_CLONE_ROOT=data/git-clones
# Public URL required for OAuth callbacks + webhook URLs (use tunnel in prod)
DEPLOW_PUBLIC_URL=http://localhost:3000
# MCP clients (Cursor): use Settings → MCP token as DEPLOW_MCP_TOKEN locally.
# Endpoint: {DEPLOW_PUBLIC_URL}/api/mcp — see docs/mcp.md
# DEPLOW_MCP_TOKEN=deplow_...
# Preferred: create GitHub App via Dashboard → Integrations (stored encrypted).
# Or set manually:
# DEPLOW_GITHUB_APP_ID=
# DEPLOW_GITHUB_APP_CLIENT_ID=
# DEPLOW_GITHUB_APP_CLIENT_SECRET=
# DEPLOW_GITHUB_APP_PRIVATE_KEY=
# DEPLOW_GITHUB_APP_WEBHOOK_SECRET=
# DEPLOW_GITHUB_APP_SLUG=
# GitLab OAuth Application (or save under Integrations)
# DEPLOW_GITLAB_OAUTH_CLIENT_ID=
# DEPLOW_GITLAB_OAUTH_CLIENT_SECRET=
# DEPLOW_GITLAB_OAUTH_BASE_URL=https://gitlab.com
# Advanced PAT fallbacks (prefer OAuth / GitHub App)
# DEPLOW_GITHUB_TOKEN=ghp_...
# DEPLOW_GITLAB_TOKEN=glpat-...
