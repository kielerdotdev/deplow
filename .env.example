# Web / auth
BETTER_AUTH_SECRET=replace-me
# Must be distinct from BETTER_AUTH_SECRET in production (install generates both).
BETTER_AUTH_URL=http://localhost:9565
DATABASE_URL=data/hostrig.db

# Platform object storage — provide your own MinIO or Cloudflare R2 (not bundled).
# Buckets (backups + per-project) are created on demand.
# Postgres/Redis are dedicated per-project containers — no shared admin URL required.
HOSTRIG_POSTGRES_IMAGE=postgres:16-alpine
HOSTRIG_REDIS_IMAGE=redis:7-alpine

# Control-plane Redis for BullMQ job queue (docker compose service: platform-redis)
# Prefer password-auth URL (compose sets --requirepass).
HOSTRIG_REDIS_PASSWORD=hostrig-dev-redis
HOSTRIG_QUEUE_REDIS_URL=redis://:hostrig-dev-redis@127.0.0.1:56380
# Set HOSTRIG_USE_QUEUE=false to fall back to in-process execution
# HOSTRIG_USE_QUEUE=true

# Public email/password sign-up: default is open only until the first instance admin.
# HOSTRIG_ALLOW_SIGNUP=0  # force off
# HOSTRIG_ALLOW_SIGNUP=1  # force on (multi-user open registration)

# Optional: allow private/RFC1918 git hosts for clone (self-hosted Gitea/GitLab)
# HOSTRIG_GIT_ALLOW_PRIVATE_HOSTS=1
# HOSTRIG_GIT_ALLOW_HOSTS=git.example.com
# Share HOSTRIG_GITHUB_TOKEN / HOSTRIG_GITLAB_TOKEN with all users (single-tenant only)
# HOSTRIG_GIT_PLATFORM_TOKEN_SHARED=1

# Trust X-Forwarded-For / X-Real-IP for rate limits (only behind a proxy that overwrites them)
# HOSTRIG_TRUST_PROXY=1

# S3 adapter: minio | r2
HOSTRIG_S3_PROVIDER=minio
HOSTRIG_S3_ENDPOINT=http://127.0.0.1:9000
HOSTRIG_S3_ACCESS_KEY=hostrig
HOSTRIG_S3_SECRET_KEY=hostrigsecret
HOSTRIG_S3_REGION=us-east-1
# HOSTRIG_S3_PUBLIC_ENDPOINT=
# HOSTRIG_S3_APP_ENDPOINT=
# HOSTRIG_S3_SCOPED_USERS=false
# R2 example:
# HOSTRIG_S3_PROVIDER=r2
# HOSTRIG_R2_ACCOUNT_ID=
# HOSTRIG_S3_ACCESS_KEY=
# HOSTRIG_S3_SECRET_KEY=
# HOSTRIG_S3_REGION=auto
HOSTRIG_BACKUP_BUCKET=hostrig-backups
# Legacy aliases (still read if HOSTRIG_S3_* unset): HOSTRIG_MINIO_*
# Daily schedule; set HOSTRIG_BACKUP_ALLOW_FAST=1 only for local demos under 1h
# HOSTRIG_BACKUP_DEFAULT_INTERVAL_MS=86400000
# HOSTRIG_BACKUP_RETAIN=7
# HOSTRIG_IMAGE_RETAIN=5
# PITR per project Postgres (pgBackRest stanza = project id — see docs/guides/backups)
HOSTRIG_PITR_ENABLED=1
# Absolute path recommended; used by host `pgbackrest` or dockerized fallback
PGBACKREST_CONFIG=./infra/pgbackrest/pgbackrest.conf
# HOSTRIG_PGBACKREST_IMAGE=woblerr/pgbackrest:2.58.0-alpine
HOSTRIG_SECRETS_KEY=replace-me-long-random

# Docker network (compose project name + _default)
HOSTRIG_DOCKER_NETWORK=hostrig_default

# User app runtime on k3s: always gVisor (runc is not allowed)
HOSTRIG_APP_RUNTIME=runsc
HOSTRIG_APP_RUNTIME_REQUIRED=true
# HOSTRIG_APP_MEMORY_MB=512
# HOSTRIG_APP_CPUS=1
# HOSTRIG_APP_READONLY_ROOTFS=true
# Per-project namespace ResourceQuota (soft multi-tenant caps)
# HOSTRIG_NS_QUOTA_PODS=20
# HOSTRIG_NS_QUOTA_REQUESTS_CPU=8
# HOSTRIG_NS_QUOTA_REQUESTS_MEMORY=8Gi
# HOSTRIG_NS_QUOTA_LIMITS_CPU=16
# HOSTRIG_NS_QUOTA_LIMITS_MEMORY=16Gi
# HOSTRIG_NS_QUOTA_PVCS=8

# Public access: app-managed domains (Domains tab in the app).
# These env vars only seed the DB on first boot; the UI is authoritative after that.
# Prefer a dedicated subzone (apps.example.com) so HOSTRIG_PUBLIC_URL can differ.
# Local: apps.localhost + http. Production: set in UI + https + Cloudflare Tunnel.
# All edges forward to http://caddy:80 (compose) or http://127.0.0.1:8088 (host).
HOSTRIG_BASE_DOMAIN=apps.localhost
HOSTRIG_PUBLIC_URL_PROTOCOL=http
HOSTRIG_PROXY_ROUTES_DIR=infra/caddy/routes
# Cloudflare Tunnel token (docker compose --profile edge)
# Zero Trust public hostname: *.apps.example.com → http://caddy:80
CLOUDFLARE_TUNNEL_TOKEN=

# Git webhook deploys + OAuth (see docs/git-oauth.md)
HOSTRIG_GIT_CLONE_ROOT=data/git-clones
# Public URL required for OAuth callbacks + webhook URLs (use tunnel in prod)
HOSTRIG_PUBLIC_URL=http://localhost:9565
# MCP clients (Cursor): use Settings → MCP token as HOSTRIG_MCP_TOKEN locally.
# Endpoint: {HOSTRIG_PUBLIC_URL}/api/mcp — see docs/mcp.md
# HOSTRIG_MCP_TOKEN=hostrig_...

# Optional: spawn agent VMs on Hetzner (Settings → Nodes). Requires a public
# HOSTRIG_PUBLIC_URL (tunnel) so the VM can join the control plane.
# HOSTRIG_HETZNER_API_TOKEN=
# HOSTRIG_HETZNER_LOCATION=fsn1
# HOSTRIG_HETZNER_SERVER_TYPE=cpx22
# HOSTRIG_HETZNER_IMAGE=ubuntu-24.04
# HOSTRIG_HETZNER_SSH_KEYS=hostrig-devvm
# Danger: unlocks vitobotta/hetzner-k3s (micro only). Token alone is not enough.

# Observe (optional — Sentry-compatible errors + OTel; requires ClickHouse)
# HOSTRIG_OBSERVE_ENABLED=1
# docker compose --profile observe up -d
# HOSTRIG_CLICKHOUSE_URL=http://127.0.0.1:8123
# HOSTRIG_CLICKHOUSE_DATABASE=hostrig_observe
# HOSTRIG_CLICKHOUSE_USER=hostrig
# HOSTRIG_CLICKHOUSE_PASSWORD=hostrig
# HOSTRIG_OBSERVE_INGEST_URL=http://localhost:9565
# HOSTRIG_OTELCOL_URL=http://127.0.0.1:4318
# HOSTRIG_OBSERVE_DEFAULT_MAX_EVENTS=10000
# HOSTRIG_OBSERVE_DEFAULT_RETENTION_DAYS=30
# Dogfood (defaults ON in development when Observe is enabled)
# Creates project "hostrig-dogfood", enables Observe, wires Sentry SDKs.
# HOSTRIG_OBSERVE_DOGFOOD=0
# HOSTRIG_OBSERVE_DOGFOOD_DSN=http://<key>@localhost:9565/<sentryId>
# HOSTRIG_OBSERVE_DOGFOOD_PROJECT_ID=<deploy-project-uuid>
# Preferred: create GitHub App via Dashboard → Integrations (stored encrypted).
# Or set manually:
# HOSTRIG_GITHUB_APP_ID=
# HOSTRIG_GITHUB_APP_CLIENT_ID=
# HOSTRIG_GITHUB_APP_CLIENT_SECRET=
# HOSTRIG_GITHUB_APP_PRIVATE_KEY=
# HOSTRIG_GITHUB_APP_WEBHOOK_SECRET=
# HOSTRIG_GITHUB_APP_SLUG=
# GitLab OAuth Application (or save under Integrations)
# HOSTRIG_GITLAB_OAUTH_CLIENT_ID=
# HOSTRIG_GITLAB_OAUTH_CLIENT_SECRET=
# HOSTRIG_GITLAB_OAUTH_BASE_URL=https://gitlab.com
# Advanced PAT fallbacks (prefer OAuth / GitHub App)
# HOSTRIG_GITHUB_TOKEN=ghp_...
# HOSTRIG_GITLAB_TOKEN=glpat-...
