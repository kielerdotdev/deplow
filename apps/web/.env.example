# SQLite — relative paths resolve from packages/db (not this app's cwd)
DATABASE_URL=data/deplow.db

# Better Auth — use a long random string in production
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Secrets encryption (can match BETTER_AUTH_SECRET in dev)
DEPLOW_SECRETS_KEY=

# PITR (pgBackRest stanza = project id)
# DEPLOW_PITR_ENABLED=1
# PGBACKREST_CONFIG=/absolute/path/to/infra/pgbackrest/pgbackrest.conf
# DEPLOW_PGBACKREST_IMAGE=woblerr/pgbackrest:2.58.0-alpine

# gVisor runtime for user apps (default runsc)
DEPLOW_APP_RUNTIME=runsc
DEPLOW_APP_RUNTIME_REQUIRED=true

# Public URL / proxy — local defaults seed the DB on first boot only.
# After that, configure Domains in the app (Domains tab).
# Edges forward to http://caddy:80 (compose) or http://127.0.0.1:8088 (host).
DEPLOW_BASE_DOMAIN=apps.localhost
DEPLOW_PUBLIC_URL_PROTOCOL=http
DEPLOW_PROXY_ROUTES_DIR=infra/caddy/routes
# Control plane public URL (OAuth, webhooks, MCP)
DEPLOW_PUBLIC_URL=http://localhost:3000
# Client-side only: Bearer token from Settings → MCP (see docs/mcp.md)
# DEPLOW_MCP_TOKEN=deplow_...
