# SQLite — relative paths resolve from packages/db (not this app's cwd)
DATABASE_URL=data/deplow.db

# Better Auth — use a long random string in production
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Secrets encryption (can match BETTER_AUTH_SECRET in dev)
DEPLOW_SECRETS_KEY=

# gVisor runtime for user apps (default runsc)
DEPLOW_APP_RUNTIME=runsc
DEPLOW_APP_RUNTIME_REQUIRED=true

# Public URL / proxy — local defaults for `vite dev`
# Production: set your real domain + https (cloudflared)
DEPLOW_BASE_DOMAIN=apps.localhost
DEPLOW_PUBLIC_URL_PROTOCOL=http
DEPLOW_PROXY_ROUTES_DIR=infra/caddy/routes
