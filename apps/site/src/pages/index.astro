---
import LandingLayout from '../layouts/LandingLayout.astro';
import Logo from '../components/landing/Logo.astro';
import DashboardMockup from '../components/landing/diagrams/DashboardMockup.astro';
import TrendsMockup from '../components/landing/diagrams/TrendsMockup.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'https://hostrig.waitforit.cc';
const repoUrl = 'https://github.com/kielerdotdev/hostrig';
const demoUrl = '/demo/hostrig-demo.mp4';
const demoPoster = '/demo/hostrig-demo-poster.jpg';
const installCmd =
	'curl -sSL https://github.com/kielerdotdev/hostrig/releases/download/install/install.sh | sudo bash';

const runtimeStrip = [
	'k3s',
	'gVisor',
	'Railpack',
	'Postgres',
	'Redis',
	'Traefik',
	'MCP',
];

const pillars = [
	{
		eyebrow: '01',
		title: 'Service-first stack',
		body: 'A project is web, worker, Postgres, and Redis services you add on demand — not a Compose catalog. Bind apps to data with explicit env keys. Destroy tears the namespace down.',
	},
	{
		eyebrow: '02',
		title: 'k3s + gVisor for apps',
		body: 'User apps schedule as Kubernetes workloads under gVisor RuntimeClass by default. Postgres and Redis run in the project namespace on the default runtime. You own the cluster.',
	},
	{
		eyebrow: '03',
		title: 'Git push + platform URL',
		body: 'Connect GitHub or GitLab once. Push the production branch; Railpack or Dockerfile builds push to your registry and roll out on k3s. Public host is {project}.{baseDomain} via edge → Traefik.',
	},
	{
		eyebrow: '04',
		title: 'Web · MCP · CLI',
		body: 'Dashboard for humans. MCP at /api/mcp for agents. Thin hostrig CLI for scripts — same operator PATs and oRPC backend. Postgres and bindings stay explicit steps.',
	},
];

const loop = [
	{
		n: '01',
		title: 'Cluster + Domains',
		body: 'Connect or create k3s. Set base domain and edge (Cloudflare, NetBird, or Tailscale).',
	},
	{
		n: '02',
		title: 'Project + services',
		body: 'Empty project. Add web/worker and Postgres/Redis when you need them. Bind DATABASE_URL / REDIS_URL.',
	},
	{
		n: '03',
		title: 'Build & ship',
		body: 'Prebuilt image, or git → Railpack/Dockerfile → your registry → k3s under gVisor.',
	},
	{
		n: '04',
		title: 'Operate',
		body: 'Logs, retry, rollback, backups to platform S3, optional Observe. Destroy cleans the project namespace.',
	},
];

const capabilities = [
	{
		n: '01',
		heading: 'Deploy',
		items: [
			{ name: 'Git push-to-deploy', desc: 'Webhooks on the production branch. Railpack or Dockerfile.' },
			{ name: 'Prebuilt images', desc: 'Skip the build when you already have a registry tag.' },
			{ name: 'Platform URL', desc: '{project}.{baseDomain} via edge → Traefik. Wildcard only in v1.' },
			{ name: 'Immutable rollbacks', desc: 'Redeploy a prior successful image in one action.' },
		],
	},
	{
		n: '02',
		heading: 'Data',
		items: [
			{ name: 'Postgres per project', desc: 'Dedicated workload + volume in the project namespace.' },
			{ name: 'Redis when you need it', desc: 'Same service model as apps — add on demand.' },
			{ name: 'Explicit bindings', desc: 'DATABASE_URL / REDIS_URL only where you wire them.' },
			{ name: 'Backups to S3', desc: 'On-demand and scheduled dumps to platform object storage.' },
		],
	},
	{
		n: '03',
		heading: 'Operate',
		items: [
			{ name: 'Web dashboard', desc: 'Full lifecycle: services, logs, secrets, cluster, domains.' },
			{ name: 'MCP for agents', desc: 'Streamable HTTP + operator PATs. Same path as the UI.' },
			{ name: 'gVisor for apps', desc: 'RuntimeClass by default. Honest limits — not MicroVMs.' },
			{ name: 'Failure webhook', desc: 'One HTTPS hook on deploy/provision failure. No notify matrix.' },
		],
	},
];

type Mark = 'win' | 'loss' | 'neutral';
type CompareLine = { feature: string; them: string; us: string; themMark: Mark; usMark: Mark };

const compareRows: CompareLine[] = [
	{
		feature: 'Runtime',
		them: 'Docker host / multi-runtime sprawl',
		us: 'One k3s cluster, gVisor apps',
		themMark: 'loss',
		usMark: 'win',
	},
	{
		feature: 'Product shape',
		them: 'Compose + templates + many DBs',
		us: 'Typed services + bindings only',
		themMark: 'neutral',
		usMark: 'win',
	},
	{
		feature: 'Isolation story',
		them: 'Plain containers (usually)',
		us: 'gVisor RuntimeClass by default',
		themMark: 'loss',
		usMark: 'win',
	},
	{
		feature: 'Interfaces',
		them: 'Panel-first',
		us: 'Web + MCP (same backend)',
		themMark: 'neutral',
		usMark: 'win',
	},
	{
		feature: 'Scope',
		them: 'Feature-matrix race',
		us: 'Railway-shaped loop, self-hosted',
		themMark: 'loss',
		usMark: 'win',
	},
];

const notFor = [
	'Docker Compose as a deploy path',
	'MySQL, Mongo, or one-click marketplaces',
	'Desktop apps (Web · MCP · CLI only)',
	'Custom domains kitchen sink (v2)',
	'Enterprise SSO / fine-grained RBAC (v1)',
	'MicroVMs or “completely secure” multi-tenant cloud claims',
];

const faqs = [
	{
		q: 'What is Hostrig, in one sentence?',
		a: 'An opinionated self-hosted PaaS: typed services on k3s, user apps under gVisor, platform wildcard URLs, git push-to-deploy, on infrastructure you control.',
	},
	{
		q: 'How is this different from Coolify or Dokploy?',
		a: 'They win breadth — Compose, templates, fleets, many databases. We win a narrow Railway-shaped path: web/worker/Postgres/Redis, explicit bindings, Traefik + edge, gVisor for apps. If you need the kitchen sink, use them.',
	},
	{
		q: 'Does MCP auto-create Postgres?',
		a: 'No. deploy_from_git creates a project (optional), analyzes the repo, creates a web service, deploys, and returns a public URL when ready. Add Postgres/Redis and bindings in the UI or with further MCP tools — same as a human would.',
	},
	{
		q: 'Do I need Kubernetes expertise?',
		a: 'You connect or create a k3s cluster once (BYO kubeconfig or managed Hetzner). Day-to-day is project → services → bind → deploy. Capacity grows by adding workers, not hand-writing Deployments for every app.',
	},
	{
		q: 'What about Observe?',
		a: 'Optional. Deploy works alone. Enable Observe (ClickHouse + flag) when you want Sentry-compatible errors, OTLP traces/metrics/logs, issues, and charts on the same control plane. Not required for GTM.',
	},
	{
		q: 'Where does HTTPS come from?',
		a: 'TLS terminates at your edge (Cloudflare Tunnel, NetBird reverse proxy, or Tailscale Serve). Traefik in the cluster is HTTP-only for this ship slice. Hostnames are platform wildcard: {project}.{baseDomain}.',
	},
	{
		q: 'How secure are user apps?',
		a: 'User apps run under gVisor on k3s with hardened pods and per-project NetworkPolicy. That is a real sandbox — not MicroVMs, not “unbreakable,” not hostile multi-tenant SaaS isolation. You trust the cluster operator and keep nodes patched. HOSTRIG_APP_RUNTIME=runc is a temporary escape hatch that turns the sandbox off.',
	},
];

const softwareLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Hostrig',
	applicationCategory: 'DeveloperApplication',
	applicationSubCategory: 'Self-hosted PaaS',
	operatingSystem: 'Linux',
	url: 'https://hostrig.com',
	downloadUrl: repoUrl,
	license: 'https://opensource.org/licenses/MIT',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	description:
		'Opinionated self-hosted PaaS on k3s: typed services, gVisor for user apps, git push-to-deploy, platform wildcard URLs. Web and MCP.',
	featureList: [
		'Service-first projects on k3s',
		'gVisor RuntimeClass for user apps',
		'Postgres and Redis with explicit bindings',
		'Git push-to-deploy',
		'MCP for agents',
		'Platform wildcard URLs via Traefik + edge',
	],
};
---

<LandingLayout
	title="Hostrig — self-hosted PaaS on k3s"
	description="Opinionated self-hosted PaaS: typed services on k3s, gVisor for user apps, git push-to-deploy, platform wildcard URLs. Web + MCP. You own the cluster."
>
	<script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />

	<nav class="nav">
		<a href="/" class="nav-brand" aria-label="Hostrig home">
			<Logo size={28} />
			<span class="nav-wordmark">Hostrig</span>
		</a>
		<div class="nav-right">
			<a href="#product" class="nav-link">Product</a>
			<a href="#loop" class="nav-link">How it works</a>
			<a href="/docs/" class="nav-link">Docs</a>
			<a href="/pricing/" class="nav-link">Pricing</a>
			<a href={repoUrl} target="_blank" rel="noopener noreferrer" class="nav-link">
				GitHub
				<span class="nav-link-arrow" aria-hidden="true">&#8599;</span>
			</a>
			<a class="nav-cta" href={appUrl}>Open app</a>
		</div>
	</nav>

	<main>
		<section class="hero">
			<button type="button" class="install-chip" data-install-chip data-cmd={installCmd}>
				<span class="install-chip-prompt" aria-hidden="true">$</span>
				<code class="install-chip-cmd">{installCmd}</code>
				<span class="install-chip-hint" data-install-hint>Copy</span>
			</button>
			<p class="brand-mark">Hostrig</p>
			<h1 class="tagline">
				<span class="tagline-main">Self-hosted PaaS on k3s.</span>
				<span class="tagline-sub">Own the cluster.</span>
			</h1>
			<p class="lede">
				Typed services, explicit bindings, public URL — apps under gVisor on a cluster you
				own. Web, MCP, or CLI. Same loop.
			</p>
			<div class="hero-actions">
				<a class="hero-button" href={appUrl}>Open app</a>
				<a class="hero-button hero-button--ghost" href="/docs/getting-started/quick-start/">
					Install self-hosted
				</a>
			</div>
			<p class="hero-secondary">
				<a class="secondary-link" href="#demo">Watch the demo →</a>
			</p>
			<ul class="runtime-strip" aria-label="Runtime">
				{runtimeStrip.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="demo-bleed" id="demo" aria-label="Product demo">
			<div class="demo-frame">
				<video
					class="demo-video"
					src={demoUrl}
					poster={demoPoster}
					autoplay
					muted
					loop
					playsinline
					controls
					preload="metadata"
				>
					Your browser does not support the video tag.
				</video>
			</div>
			<p class="demo-caption">
				Project → services → bind → deploy. Same path in the UI or via MCP.
			</p>
		</section>

		<section class="band" id="product">
			<div class="band-head">
				<p class="mode-label">The product</p>
				<h2>Railway-shaped. Self-hosted. Honest sandbox.</h2>
				<p>
					Coolify wins the feature list. Hosted PaaS wins convenience. Hostrig wins a boring,
					opinionated path on a cluster you control.
				</p>
			</div>
			<div class="moat-list">
				{
					pillars.map((m) => (
						<article class="moat-item">
							<span class="moat-n">{m.eyebrow}</span>
							<h3>{m.title}</h3>
							<p>{m.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="band band--dark" id="capabilities" aria-label="Capabilities">
			<div class="band-head band-head--on-dark">
				<p class="mode-label">Platform</p>
				<h2>What we ship. Nothing else.</h2>
				<p>Three groups. No 40-item matrix. If it is not here, it is out of scope on purpose.</p>
			</div>
			<div class="cap-grid">
				{
					capabilities.map((g) => (
						<div class="cap-group">
							<div class="cap-group-head">
								<span class="cap-n">{g.n}</span>
								<h3>{g.heading}</h3>
							</div>
							<ul class="cap-list">
								{g.items.map((item) => (
									<li>
										<strong>{item.name}</strong>
										<span>{item.desc}</span>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</section>

		<section class="band prompt-band" id="agent" aria-label="Agent deploy">
			<div class="band-head">
				<p class="mode-label">MCP</p>
				<h2>Agents can drive the same lifecycle.</h2>
				<p>
					Streamable HTTP at <code>/api/mcp</code>. Operator tokens under Settings → API &amp;
					MCP. <code>deploy_from_git</code> ships a repo to a web service URL — it does not invent
					Postgres or bindings for you.
				</p>
			</div>
			<div class="prompt-stage" data-prompt-stage>
				<div class="prompt-row">
					<span class="prompt-who">YOU</span>
					<p class="prompt-bubble mono">
						<span data-typed></span><span class="caret" data-caret></span>
					</p>
				</div>
				<div class="prompt-row prompt-row--agent" data-agent-row>
					<span class="prompt-who prompt-who--agent">AI</span>
					<div class="prompt-bubble">
						<p>Deploying the web service from that repo…</p>
						<ul class="prompt-steps">
							<li data-step>Create project</li>
							<li data-step>Analyze source</li>
							<li data-step>Create web service + deploy</li>
							<li data-step>Poll until running</li>
							<li data-step class="ok">https://showcase.apps.example.com</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="band" id="loop">
			<div class="band-head">
				<p class="mode-label">The loop</p>
				<h2>Four moves. No detours.</h2>
				<p>Same path whether a human or an agent drives it.</p>
			</div>
			<ol class="steps">
				{
					loop.map((s) => (
						<li>
							<span class="step-n">{s.n}</span>
							<div>
								<h3>{s.title}</h3>
								<p>{s.body}</p>
							</div>
						</li>
					))
				}
			</ol>
		</section>

		<section class="band band--shot">
			<figure class="shot">
				<div class="browser-chrome" aria-hidden="true">
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="url">app / projects / showcase</span>
				</div>
				<div class="shot-frame">
					<DashboardMockup />
				</div>
				<figcaption>
					Deploy overview — nested shell, dense service rows, bindings to Postgres/Redis.
				</figcaption>
			</figure>
		</section>

		<section class="band" id="compare">
			<div class="band-head">
				<p class="mode-label">Positioning</p>
				<h2>Not Coolify-shaped. Not a Docker panel.</h2>
				<p>
					If you need Compose + every database + templates, use the panels that chase that. If
					you want sandboxed app + Postgres + Redis + S3 on k3s with git push, use us.
				</p>
			</div>
			<div class="cmp">
				<div class="cmp-row cmp-row--head">
					<div class="cmp-cell cmp-cell--feature">Feature</div>
					<div class="cmp-cell">Coolify / Dokploy</div>
					<div class="cmp-cell cmp-cell--win">Hostrig</div>
				</div>
				{
					compareRows.map((r) => (
						<div class="cmp-row">
							<div class="cmp-cell cmp-cell--feature">{r.feature}</div>
							<div class="cmp-cell">
								<span class={`cmp-mark cmp-mark--${r.themMark}`} aria-hidden="true" />
								<span>{r.them}</span>
							</div>
							<div class="cmp-cell cmp-cell--win">
								<span class={`cmp-mark cmp-mark--${r.usMark}`} aria-hidden="true" />
								<span>{r.us}</span>
							</div>
						</div>
					))
				}
			</div>
		</section>

		<section class="band band--shot" id="observe">
			<div class="band-head">
				<p class="mode-label">Optional</p>
				<h2>Observe when you need signal</h2>
				<p>
					Sentry-compatible errors, OTLP traces / metrics / logs, issues, and charts — same
					control plane, ClickHouse-backed. Not required to ship. Not the lead story.
				</p>
			</div>
			<figure class="shot">
				<div class="browser-chrome" aria-hidden="true">
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="url">app / observe / showcase / charts</span>
				</div>
				<div class="shot-frame">
					<TrendsMockup />
				</div>
				<figcaption>
					Same shell as Deploy — dark nested chrome, charts and tables, no separate product UI.
				</figcaption>
			</figure>
			<p style="margin-top: 1.25rem">
				<a class="inline-link" href="/docs/guides/observe/">Observe setup →</a>
			</p>
		</section>

		<section class="band" id="not-for">
			<div class="band-head">
				<h2>Out of scope on purpose</h2>
				<p>
					Narrow tool, thick pen.
					<a class="inline-link" href="/docs/concepts/scope/">Full list →</a>
				</p>
			</div>
			<ul class="out-list">
				{notFor.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="band" id="faq">
			<div class="band-head">
				<h2>Questions</h2>
			</div>
			<div class="faq">
				{
					faqs.map((f) => (
						<details>
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>
		</section>

		<section class="cta" aria-label="Get started">
			<div class="cta-panel">
				<h2>Ship the first URL on your cluster.</h2>
				<p>Connect k3s, add a service, deploy. Web or MCP — same path.</p>
				<div class="cta-actions">
					<a class="hero-button" href={appUrl}>Open app</a>
					<a class="hero-button hero-button--ghost" href="/docs/getting-started/quick-start/">
						Install self-hosted
					</a>
				</div>
				<ul class="trust-chips">
					<li>Web · MCP · CLI</li>
					<li>gVisor apps</li>
					<li>You own the cluster</li>
					<li>No credit card</li>
				</ul>
			</div>
		</section>
	</main>

	<footer class="footer">
		<a href="/" class="footer-brand" aria-label="Hostrig home">Hostrig</a>
		<div class="footer-links">
			<a href="#product">Product</a>
			<a href="#loop">How it works</a>
			<a href="/docs/">Docs</a>
			<a href="/pricing/">Pricing</a>
			<a href={appUrl}>App</a>
			<a href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
		<span class="footer-meta">&copy; {new Date().getFullYear()} · MIT</span>
	</footer>

	<script>
		const prompt = 'Deploy my app from github.com/org/showcase and give me the URL.';
		const typed = document.querySelector('[data-typed]');
		const caret = document.querySelector('[data-caret]');
		const agentRow = document.querySelector('[data-agent-row]');
		const steps = [...document.querySelectorAll('[data-step]')];
		const stage = document.querySelector('[data-prompt-stage]');

		const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

		async function runPrompt() {
			if (!typed || !stage) return;
			const io = new IntersectionObserver(
				async ([entry]) => {
					if (!entry?.isIntersecting) return;
					io.disconnect();
					typed.textContent = '';
					for (const ch of prompt) {
						typed.textContent += ch;
						await sleep(28);
					}
					caret?.classList.add('off');
					await sleep(200);
					agentRow?.classList.add('on');
					for (const step of steps) {
						await sleep(280);
						step.classList.add('on');
					}
				},
				{ threshold: 0.35 },
			);
			io.observe(stage);
		}

		runPrompt();

		const chip = document.querySelector('[data-install-chip]') as HTMLButtonElement | null;
		const hint = document.querySelector('[data-install-hint]');
		chip?.addEventListener('click', async () => {
			const cmd = chip.dataset.cmd ?? '';
			try {
				await navigator.clipboard.writeText(cmd);
				if (hint) hint.textContent = 'Copied';
				setTimeout(() => {
					if (hint) hint.textContent = 'Copy';
				}, 1600);
			} catch {
				if (hint) hint.textContent = 'Select & copy';
			}
		});
	</script>
</LandingLayout>
