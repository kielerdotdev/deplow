---
import LandingLayout from '../layouts/LandingLayout.astro';
import Logo from '../components/landing/Logo.astro';
import DashboardMockup from '../components/landing/diagrams/DashboardMockup.astro';
import TrendsMockup from '../components/landing/diagrams/TrendsMockup.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3000';
const repoUrl = 'https://github.com/deplow/deplow';
const installCmd =
	'git clone https://github.com/deplow/deplow.git && cd deplow && bash scripts/install.sh && pnpm dev';

const deployPillars = [
	{
		title: 'One loop, not a catalog',
		body: 'Add services, bind them, deploy, get a URL. No Compose files, no template marketplace.',
	},
	{
		title: 'gVisor by default',
		body: 'User apps run under runsc. Platform Postgres and Redis stay on runc. Missing gVisor fails the deploy — no quiet fallback.',
	},
	{
		title: 'Bindings, not env dumps',
		body: 'Wire DATABASE_URL and REDIS_URL explicitly. Credentials scoped per binding, encrypted at rest.',
	},
];

const deploySteps = [
	{ n: '1', title: 'Create', body: 'Postgres, Redis, bucket. Credentials encrypted at rest.' },
	{ n: '2', title: 'Build', body: 'Railpack, Dockerfile, or pull a prebuilt image.' },
	{ n: '3', title: 'Run', body: 'Env injected. Container starts under gVisor on your host.' },
	{ n: '4', title: 'Back up', body: 'Scheduled pg_dump into the platform bucket.' },
];

const observePillars = [
	{
		title: 'Trends query builder',
		body: 'Multi-series A/B/C, arithmetic formulas, nested filter groups, breakdowns, baseline overlay — chart plus exact results table.',
	},
	{
		title: 'Traces, logs, issues',
		body: 'Explore heatmaps, dig-down into traces and logs, group errors into issues. Same Context time range across surfaces.',
	},
	{
		title: 'Dashboards from saved charts',
		body: 'Save a Trends query as an Insight, place it on a dashboard, override period and group-by without rebuilding the chart.',
	},
];

const trendsFeatures = [
	{ label: 'Series', detail: 'Spans, root spans, logs, errors — count, rate, percentiles, error rate' },
	{ label: 'Formulas', detail: 'B/A×100 and friends over aligned buckets' },
	{ label: 'Filters', detail: 'Nested AND / OR / NOT groups, per-series and global' },
	{ label: 'Breakdowns', detail: 'Top-N + Other, cardinality warnings' },
	{ label: 'Compare', detail: 'Previous-period baseline on the same chart' },
	{ label: 'Export', detail: 'CSV of exact buckets, or query + result JSON' },
];

const notFor = [
	'Compose as a deploy path',
	'MySQL, Mongo, or template marketplaces',
	'Product analytics funnels / retention / paths',
	'Multi-server fleets or kube operators',
	'SSO or a public CLI (v1)',
];

const faqs = [
	{
		q: 'How is this different from Coolify or Dokploy?',
		a: 'They cover more surface area — Compose, templates, fleets. deplow is a Railway-style loop on one host with gVisor on user code, plus an Observe mode for OTEL traces, logs, and Trends charts.',
	},
	{
		q: 'What is Observe?',
		a: 'Optional ClickHouse-backed observability in the same control plane. Ingest OpenTelemetry / Sentry-compatible envelopes, then query with Trends, Explore, Traces, Logs, and Issues.',
	},
	{
		q: 'Do I have to use Observe to deploy?',
		a: 'No. Deploy works alone. Enable Observe per project when you want charts and dig-down on the same host.',
	},
	{
		q: 'Where does HTTPS come from?',
		a: 'TLS terminates at Cloudflare on the tunnel. Caddy on the host is HTTP-only in v1.',
	},
];
---

<LandingLayout
	title="deplow — deploy & observe on your host"
	description="Self-hosted deploy under gVisor, plus Trends observability: multi-series charts, traces, logs, and dashboards on your Docker host."
>
	<nav class="nav">
		<a href="/" class="nav-brand" aria-label="deplow home">
			<Logo size={28} />
			<span class="nav-wordmark">deplow</span>
		</a>
		<div class="nav-right">
			<a href="#deploy" class="nav-link">Deploy</a>
			<a href="#observe" class="nav-link">Observe</a>
			<a href="/docs/" class="nav-link">Docs</a>
			<a href={repoUrl} target="_blank" rel="noopener noreferrer" class="nav-link">
				GitHub
				<span class="nav-link-arrow" aria-hidden="true">&#8599;</span>
			</a>
		</div>
	</nav>

	<main>
		<section class="hero">
			<p class="brand-mark">deplow</p>
			<h1 class="tagline">Deploy and observe<br />on your host.</h1>
			<p class="lede">
				One Docker machine: ship apps under gVisor, then dig into traces, logs, and
				Trends charts without bolting on a second SaaS.
			</p>

			<div class="hero-actions">
				<a class="hero-button" href="/docs/getting-started/quick-start/">Get started</a>
				<a class="secondary-link" href="#observe">See Observe →</a>
			</div>

			<div class="install" data-install>
				<span class="prompt">$</span>
				<code>{installCmd}</code>
				<button type="button" class="copy" aria-label="Copy install command" data-copy={installCmd}>
					Copy
				</button>
			</div>
		</section>

		<!-- Split product rail -->
		<section class="split" aria-label="Deploy and Observe">
			<a class="split-pane split-pane--deploy" href="#deploy">
				<span class="split-kicker">01 · Deploy</span>
				<strong class="split-title">Ship the stack</strong>
				<p class="split-body">
					Web + Postgres + Redis, explicit bindings, git push, wildcard URL.
					User code sandboxed under gVisor.
				</p>
				<span class="split-cta">Explore Deploy →</span>
			</a>
			<a class="split-pane split-pane--observe" href="#observe">
				<span class="split-kicker">02 · Observe</span>
				<strong class="split-title">Query the signal</strong>
				<p class="split-body">
					Trends multi-series builder, Explore dig-down, traces, logs, issues,
					and dashboards from saved charts.
				</p>
				<span class="split-cta">Explore Observe →</span>
			</a>
		</section>

		<!-- DEPLOY -->
		<section class="band" id="deploy">
			<div class="mode-label">Deploy</div>
			<div class="band-head">
				<h2>What Deploy actually does</h2>
				<p>
					Most self-hosted panels try to run everything. We run the stack most
					apps need — and isolate the code you did not write.
				</p>
			</div>
			<div class="diff-list">
				{
					deployPillars.map((d) => (
						<div class="diff-item">
							<h3>{d.title}</h3>
							<p>{d.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="band" id="how-deploy">
			<div class="band-head">
				<h2>How Deploy works</h2>
				<p>Four steps from install to running app. No resource catalog in the middle.</p>
			</div>
			<ol class="steps">
				{
					deploySteps.map((s) => (
						<li>
							<span class="step-n">{s.n}</span>
							<div>
								<h3>{s.title}</h3>
								<p>{s.body}</p>
							</div>
						</li>
					))
				}
			</ol>
		</section>

		<section class="band band--shot">
			<figure class="shot">
				<div class="browser-chrome" aria-hidden="true">
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="url">localhost:3000 / projects / acme-shop</span>
				</div>
				<div class="shot-frame">
					<DashboardMockup />
				</div>
				<figcaption>
					Project stack — apps on the left, data on the right, bindings in between.
				</figcaption>
			</figure>
		</section>

		<!-- OBSERVE -->
		<section class="band" id="observe">
			<div class="mode-label mode-label--observe">Observe</div>
			<div class="band-head">
				<h2>Observability that lives next to Deploy</h2>
				<p>
					Ingest OpenTelemetry on the same host. Build charts with Trends, dig
					into traces and logs, save Insights onto dashboards — one Context bar
					for time and filters.
				</p>
			</div>
			<div class="diff-list">
				{
					observePillars.map((d) => (
						<div class="diff-item">
							<h3>{d.title}</h3>
							<p>{d.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="band band--shot" id="trends">
			<figure class="shot">
				<div class="browser-chrome" aria-hidden="true">
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="url">localhost:3010 / observe / projects / … / trends</span>
				</div>
				<div class="shot-frame">
					<TrendsMockup />
				</div>
				<figcaption>
					Trends — left builder (series, formulas, filters, breakdown), chart with
					baseline, exact results grid, CSV / JSON export.
				</figcaption>
			</figure>
		</section>

		<section class="band" id="trends-features">
			<div class="band-head">
				<h2>Trends, in one pass</h2>
				<p>
					PostHog-style visual query builder for ops signals — not product
					analytics. Phase 1 ships the loop you use every day.
				</p>
			</div>
			<ul class="feature-rail">
				{
					trendsFeatures.map((f) => (
						<li>
							<span class="feature-label">{f.label}</span>
							<span class="feature-detail">{f.detail}</span>
						</li>
					))
				}
			</ul>
		</section>

		<section class="band" id="observe-surfaces">
			<div class="band-head">
				<h2>The rest of Observe</h2>
				<p>Trends is the deep builder. These surfaces share the same Context.</p>
			</div>
			<div class="surface-grid">
				<div class="surface-item">
					<h3>Explore</h3>
					<p>Duration heatmap with brush dig-down into the time window that matters.</p>
				</div>
				<div class="surface-item">
					<h3>Traces &amp; logs</h3>
					<p>Waterfalls, correlated logs, attribute filters — jump from chart to span.</p>
				</div>
				<div class="surface-item">
					<h3>Issues</h3>
					<p>Grouped errors with stack frames, status, and links back into traces.</p>
				</div>
				<div class="surface-item">
					<h3>Dashboards</h3>
					<p>Place saved Trends charts as widgets; override period and group-by per board.</p>
				</div>
			</div>
		</section>

		<section class="band" id="not-for">
			<div class="band-head">
				<h2>Out of scope</h2>
				<p>
					Narrow on purpose. If you need Coolify’s breadth or a full product-analytics
					suite, use those tools.
					<a class="inline-link" href="/docs/concepts/scope/">Full Deploy list →</a>
				</p>
			</div>
			<ul class="out-list">
				{notFor.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="band" id="faq">
			<div class="band-head">
				<h2>Questions</h2>
			</div>
			<div class="faq">
				{
					faqs.map((f) => (
						<details>
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>
		</section>

		<section class="cta">
			<h2>Install on your host</h2>
			<p>Bootstrap Deploy. Flip on Observe when you want Trends and dig-down.</p>
			<div class="hero-actions">
				<a class="hero-button" href="/docs/getting-started/quick-start/">Read quick start</a>
				<a class="secondary-link" href={appUrl}>Open dashboard</a>
			</div>
		</section>
	</main>

	<footer class="footer">
		<span>&copy; {new Date().getFullYear()} deplow · MIT</span>
		<div class="footer-links">
			<a href="#deploy">Deploy</a>
			<a href="#observe">Observe</a>
			<a href="/docs/">Docs</a>
			<a href={appUrl}>Dashboard</a>
			<a href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</footer>

	<script>
		const copyBtn = document.querySelector('[data-copy]');
		copyBtn?.addEventListener('click', async () => {
			const text = copyBtn.getAttribute('data-copy') ?? '';
			try {
				await navigator.clipboard.writeText(text);
				copyBtn.textContent = 'Copied';
				setTimeout(() => {
					copyBtn.textContent = 'Copy';
				}, 1400);
			} catch {
				/* noop */
			}
		});
	</script>
</LandingLayout>
