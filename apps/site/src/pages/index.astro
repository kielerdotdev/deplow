---
import LandingLayout from '../layouts/LandingLayout.astro';
import Logo from '../components/landing/Logo.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3000';
const repoUrl = 'https://github.com/deplow/deplow';
const installCmd =
	'git clone https://github.com/deplow/deplow.git && cd deplow && bash scripts/install.sh && pnpm dev';

const differentiators = [
	{
		title: 'One loop, not a catalog',
		body: 'Add services, bind them, deploy, get a URL. No Compose files, no template marketplace, no database picker with twelve options.',
	},
	{
		title: 'gVisor by default',
		body: 'User apps run under runsc. Platform Postgres, Redis, and Caddy stay on runc. If gVisor is missing, the deploy fails — we do not fall back quietly.',
	},
	{
		title: 'Bindings, not env dumps',
		body: 'Wire DATABASE_URL and REDIS_URL explicitly between services. Credentials are scoped per binding, not pasted into one giant env block.',
	},
];

const steps = [
	{ kind: 'create' as const, n: '1', title: 'Create', body: 'Spin up postgres, redis, and a bucket. Credentials encrypted at rest.' },
	{ kind: 'build' as const, n: '2', title: 'Build', body: 'Railpack, Dockerfile, or pull a prebuilt image. Same path every time.' },
	{ kind: 'run' as const, n: '3', title: 'Run', body: 'Env vars injected. Container starts under gVisor on your host.' },
	{ kind: 'backup' as const, n: '4', title: 'Back up', body: 'Scheduled pg_dump into the platform bucket. No extra cron to write.' },
];

const stackItems = [
	'SQLite holds project metadata',
	'Postgres, redis, minio hold workload data',
	'Docker runs the host; user apps run under gVisor',
	'No ssh nodes, no swarm, no kube operator',
];

const sandboxChecks = [
	{ strong: 'gVisor, not runc.', rest: 'User apps get a forged kernel — syscalls like ptrace and /proc poking are blocked at the boundary.' },
	{ strong: 'Platform services stay privileged.', rest: 'Postgres, redis, and the control plane run on runc. Trusted, fast, no perf tax where you don’t need it.' },
	{ strong: 'Per-project isolation.', rest: 'Docker networks and volumes separate every project’s data plane. One noisy neighbour can’t read another’s rows.' },
	{ strong: 'Secrets never touch images.', rest: 'Env vars are injected at runtime and encrypted at rest. <b>Zero</b> plaintext leakage into build logs.' },
];

const competitors = [
	{ name: 'Heroku', blurb: 'deplow runs in your cloud, one host, with a real sandbox — no dyno dynasty to outgrow.' },
	{ name: 'Vercel', blurb: 'Bring your backend, not just your frontend. <b>Full-stack</b> per project, not per preview.' },
	{ name: 'Render', blurb: 'One host, one bill. gVisor isolation where Render charges you per service for it.' },
	{ name: 'Railway', blurb: 'Self-hosted and self-owned. <b>No usage grid</b>, no surprise dollar graph at 3am.' },
	{ name: 'Dokploy', blurb: 'A control plane with a sandbox-first runtime. deplow ships gVisor by default, full stop.' },
	{ name: 'Coolify', blurb: 'Faster local setup, a smaller surface, and the loop you can explain in one breath.' },
	{ name: 'Dokku', blurb: 'Same single-host honesty. deplow adds a typed API, scheduled backups, and a real UI.' },
	{ name: 'Porter', blurb: 'For when you’ve outgrown hand-tuned kube — <b>drift back</b> to one host without losing the platform.' },
];

const faqs = [
	{
		n: '01',
		title: 'Install',
		body: 'One script checks BuildKit, Railpack, and gVisor, then starts platform services on your Docker host.',
	},
	{
		n: '02',
		title: 'Wildcard domain',
		body: 'Set a base domain in Domains. Cloudflare Tunnel handles TLS; Caddy on the host stays HTTP-only.',
	},
	{
		n: '03',
		title: 'Stack & bind',
		body: 'Create a project, add web + Postgres + Redis, bind the app to data, deploy from git or the dashboard.',
	},
	{
		n: '04',
		title: 'Run it',
		body: 'Live logs, retries, clean teardown. Scheduled pg_dump goes to platform MinIO.',
	},
];

const notFor = [
	'Compose as a deploy path',
	'MySQL, Mongo, or template marketplaces',
	'Custom domains or PR previews (v2)',
	'Multi-server fleets',
	'SSO or a public CLI',
];

const faqs = [
	{
		q: 'How is this different from Coolify or Dokploy?',
		a: 'They cover more surface area — Compose, templates, many databases, fleets. deplow does one thing: a Railway-style loop on a single host, with gVisor on user code. Need the kitchen sink? Use them. Need sandboxed app + Postgres + Redis + git push? Use us.',
	},
	{
		q: 'Where does HTTPS come from?',
		a: 'TLS terminates at Cloudflare on the tunnel. Caddy on the host is HTTP-only in v1.',
	},
	{
		q: 'Can I attach a custom domain?',
		a: 'Not in v1. Web services get URLs under your platform wildcard (*.{baseDomain}). Custom domains are planned for v2.',
	},
	{
		q: 'Is there a CLI or public API?',
		a: 'No typed CLI and no general REST API in v1. Dashboard-first. MCP tokens exist for agents — they are not a product API.',
	},
];
---

<LandingLayout
	title="deplow — self-hosted apps under gVisor"
	description="Deploy web apps, Postgres, and Redis on your Docker host. Explicit bindings, git push deploys, wildcard URLs — with user code sandboxed under gVisor."
>
	<nav class="nav">
		<a href="/" class="nav-brand" aria-label="deplow home">
			<Logo size={28} />
			<span class="nav-wordmark">deplow</span>
		</a>
		<div class="nav-right">
			<a href="/docs/" class="nav-link">Docs</a>
			<a href={repoUrl} target="_blank" rel="noopener noreferrer" class="nav-link">
				GitHub
				<span class="nav-link-arrow" aria-hidden="true">&#8599;</span>
			</a>
		</div>
	</nav>

	<main>
		<section class="hero">
			<h1 class="tagline">Deploy on your host.<br />Sandboxed by default.</h1>
			<p class="lede">
				A control plane for one Docker machine — add services, bind Postgres and
				Redis, deploy from git, get a wildcard URL. User code runs under gVisor.
			</p>

			<div class="hero-actions">
				<a class="hero-button" href="/docs/getting-started/quick-start/">Get started</a>
				<a class="secondary-link" href="/docs/concepts/scope/">What we don’t build</a>
			</div>

			<div class="install" data-install>
				<span class="prompt">$</span>
				<code>{installCmd}</code>
				<button type="button" class="copy" aria-label="Copy install command" data-copy={installCmd}>
					Copy
				</button>
			</div>

			<figure class="shot shot--hero">
				<div class="browser-chrome" aria-hidden="true">
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="dot"></span>
				<span class="url">localhost:3000 / projects / acme-shop</span>
			</div>
			<img
				src="/screenshots/dashboard.jpeg"
				alt="deplow project overview for acme-shop with web, postgres, and redis services"
				width="1440"
				height="900"
				loading="eager"
			/>
			<figcaption>
				Project stack — apps on the left, data on the right, bindings in between.
			</figcaption>
			</figure>
		</section>

		<section class="band" id="different">
			<div class="band-head">
				<h2>What we actually do</h2>
				<p>
					Most self-hosted panels try to run everything. We run the stack most
					apps need — and isolate the code you did not write.
				</p>
			</div>
			<div class="diff-list">
				{
					differentiators.map((d) => (
						<div class="diff-item">
							<h3>{d.title}</h3>
							<p>{d.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="band" id="how">
			<div class="band-head">
				<h2>How it works</h2>
				<p>Four steps from install to running app. No resource catalog in the middle.</p>
			</div>
			<ol class="steps">
				{
					steps.map((s) => (
						<li>
							<span class="step-n">{s.n}</span>
							<div>
								<h3>{s.title}</h3>
								<p>{s.body}</p>
							</div>
						</li>
					))
				}
			</ol>
		</section>

		<section class="band band--shot">
			<figure class="shot">
				<div class="browser-chrome" aria-hidden="true">
					<span class="dot"></span>
					<span class="dot"></span>
					<span class="dot"></span>
				<span class="url">localhost:3000 / home</span>
			</div>
			<img
				src="/screenshots/home.jpeg"
				alt="deplow home dashboard showing projects, nodes, and GitHub integration"
				width="1440"
				height="900"
				loading="lazy"
			/>
			<figcaption>
				Home — your projects and platform settings in one place.
			</figcaption>
			</figure>
		</section>

		<section class="band" id="not-for">
			<div class="band-head">
				<h2>Out of scope</h2>
				<p>
					Narrow on purpose. If you need Coolify’s breadth, use Coolify.
					<a class="inline-link" href="/docs/concepts/scope/">Full list →</a>
				</p>
			</div>
			<ul class="out-list">
				{notFor.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="band" id="faq">
			<div class="band-head">
				<h2>Questions</h2>
			</div>
			<div class="faq">
				{
					faqs.map((f) => (
						<details>
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>
		</section>

		<section class="cta">
			<h2>Install on your host</h2>
			<p>Bootstrap, set your wildcard, deploy. That is the whole launch path.</p>
			<div class="hero-actions">
				<a class="hero-button" href="/docs/getting-started/quick-start/">Read quick start</a>
				<a class="secondary-link" href={appUrl}>Open dashboard</a>
			</div>
		</section>
	</main>

	<footer class="footer">
		<span>&copy; {new Date().getFullYear()} deplow · MIT</span>
		<div class="footer-links">
			<a href="/docs/">Docs</a>
			<a href="/docs/concepts/scope/">Scope</a>
			<a href={appUrl}>Dashboard</a>
			<a href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</footer>

	<script>
		const copyBtn = document.querySelector('[data-copy]');
		copyBtn?.addEventListener('click', async () => {
			const text = copyBtn.getAttribute('data-copy') ?? '';
			try {
				await navigator.clipboard.writeText(text);
				copyBtn.textContent = 'Copied';
				setTimeout(() => {
					copyBtn.textContent = 'Copy';
				}, 1400);
			} catch {
				/* noop */
			}
		});
	</script>
</LandingLayout>
