---
interface Props {
	size?: number;
}

const { size = 24 } = Astro.props;
---

<svg class="brand-logo" width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
	<rect x="2.5" y="4.5" width="27" height="23" rx="6" fill="none" stroke="currentColor" stroke-width="2" />
	<path
		d="M9 16h10M19 16l-4.5-4M19 16l-4.5 4"
		stroke="currentColor"
		stroke-width="2.2"
		stroke-linecap="round"
		stroke-linejoin="round"
	/>
	<rect x="22" y="11.5" width="4.5" height="9" rx="1.25" fill="currentColor" opacity="0.9" />
</svg>
