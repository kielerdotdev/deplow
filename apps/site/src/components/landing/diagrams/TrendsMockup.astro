---
/**
 * Product mockup — Observe Charts / trends (dark Atlasflow).
 * Colors match apps/web dark shell; IA matches current nav (no Explore).
 */
const font = "DM Sans, system-ui, sans-serif"
const mono = "IBM Plex Mono, ui-monospace, monospace"
---

<svg
	viewBox="0 0 1280 800"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	role="img"
	aria-label="Hostrig Observe charts: dark nested chrome with series chart and table"
>
	<defs>
		<linearGradient id="areaA" x1="0" y1="0" x2="0" y2="1">
			<stop stop-color="#60a5fa" stop-opacity="0.22" />
			<stop offset="1" stop-color="#60a5fa" stop-opacity="0" />
		</linearGradient>
	</defs>

	<rect width="1280" height="800" fill="#000000" />

	<!-- crumb -->
	<rect width="1280" height="48" fill="#0a0a0a" />
	<rect y="47" width="1280" height="1" fill="#2e2e2e" />

	<g transform="translate(14 10)">
		<rect x="0.5" y="1.5" width="23" height="19" rx="4" stroke="#f2f2f2" stroke-width="1.6" fill="none" />
		<path
			d="M6 12h8.5M14.5 12l-3.5-3.2M14.5 12l-3.5 3.2"
			stroke="#f2f2f2"
			stroke-width="1.7"
			stroke-linecap="round"
			stroke-linejoin="round"
		/>
		<rect x="17.5" y="7.5" width="3.5" height="7.5" rx="0.9" fill="#f2f2f2" opacity="0.9" />
	</g>

	<circle cx="62" cy="24" r="10" fill="#242424" />
	<text x="62" y="27.5" fill="#b0b0b0" font-family={font} font-size="8" font-weight="700" text-anchor="middle">MA</text>
	<text x="78" y="28" fill="#f2f2f2" font-family={font} font-size="13" font-weight="500">Marketing</text>
	<text x="150" y="28" fill="#525252" font-family={font} font-size="13">/</text>
	<circle cx="174" cy="24" r="10" fill="#242424" />
	<text x="174" y="27.5" fill="#b0b0b0" font-family={font} font-size="8" font-weight="700" text-anchor="middle">SH</text>
	<text x="190" y="28" fill="#f2f2f2" font-family={font} font-size="13" font-weight="500">showcase</text>

	<!-- Deploy | Observe mode hint -->
	<rect x="560" y="11" width="72" height="26" rx="4" fill="#0a0a0a" stroke="#333" />
	<text x="596" y="28" fill="#8a8a8a" font-family={font} font-size="11" text-anchor="middle">Deploy</text>
	<rect x="636" y="11" width="80" height="26" rx="4" fill="#2a2a2a" />
	<text x="676" y="28" fill="#f2f2f2" font-family={font} font-size="11" font-weight="500" text-anchor="middle">Observe</text>

	<rect x="1000" y="10" width="188" height="28" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="1014" y="28" fill="#8a8a8a" font-family={font} font-size="11">Search…</text>
	<circle cx="1236" cy="24" r="12" fill="#242424" />
	<text x="1236" y="27.5" fill="#b0b0b0" font-family={font} font-size="8" font-weight="700" text-anchor="middle">MA</text>

	<!-- observe tabs -->
	<rect y="48" width="1280" height="44" fill="#0a0a0a" />
	<rect y="91" width="1280" height="1" fill="#2e2e2e" />
	<text x="48" y="74" fill="#8a8a8a" font-family={font} font-size="12" text-anchor="middle">Overview</text>
	<text x="128" y="74" fill="#8a8a8a" font-family={font} font-size="12" text-anchor="middle">Services</text>
	<rect x="168" y="56" width="64" height="28" rx="4" fill="#2a2a2a" />
	<text x="200" y="74" fill="#f2f2f2" font-family={font} font-size="12" font-weight="500" text-anchor="middle">Charts</text>
	<text x="280" y="74" fill="#8a8a8a" font-family={font} font-size="12" text-anchor="middle">Traces</text>
	<text x="348" y="74" fill="#8a8a8a" font-family={font} font-size="12" text-anchor="middle">Logs</text>
	<text x="410" y="74" fill="#8a8a8a" font-family={font} font-size="12" text-anchor="middle">Issues</text>

	<!-- nested panel -->
	<rect x="10" y="100" width="1260" height="690" rx="6" fill="#121212" stroke="#2e2e2e" />

	<!-- context bar -->
	<rect x="22" y="114" width="1236" height="40" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="40" y="138" fill="#8a8a8a" font-family={mono} font-size="11">Last 1h</text>
	<rect x="120" y="122" width="1" height="24" fill="#333" />
	<text x="136" y="138" fill="#b0b0b0" font-family={font} font-size="12">service:web · env:production</text>
	<rect x="1120" y="122" width="120" height="24" rx="4" fill="#242424" />
	<text x="1180" y="138" fill="#f2f2f2" font-family={font} font-size="11" text-anchor="middle">Run query</text>

	<!-- chart card -->
	<rect x="22" y="170" width="1236" height="320" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="40" y="198" fill="#f2f2f2" font-family={font} font-size="12" font-weight="500">Request rate</text>
	<text x="140" y="198" fill="#8a8a8a" font-family={font} font-size="11">p95 latency overlay · 1m buckets</text>
	<circle cx="1180" cy="194" r="4" fill="#60a5fa" />
	<text x="1192" y="198" fill="#8a8a8a" font-family={font} font-size="11">rate</text>
	<circle cx="1236" cy="194" r="4" fill="#22c55e" />
	<text x="1248" y="198" fill="#8a8a8a" font-family={font} font-size="11">p95</text>

	<!-- grid -->
	{[230, 290, 350, 410, 450].map((y) => (
		<line x1="40" y1={y} x2="1230" y2={y} stroke="#333" stroke-opacity="0.55" />
	))}

	<!-- area + lines -->
	<path
		d="M40 420 L140 380 L240 390 L340 340 L440 360 L540 300 L640 320 L740 280 L840 300 L940 250 L1040 270 L1140 230 L1230 240 L1230 450 L40 450 Z"
		fill="url(#areaA)"
	/>
	<path
		d="M40 420 L140 380 L240 390 L340 340 L440 360 L540 300 L640 320 L740 280 L840 300 L940 250 L1040 270 L1140 230 L1230 240"
		stroke="#60a5fa"
		stroke-width="2"
		fill="none"
		stroke-linecap="round"
		stroke-linejoin="round"
	/>
	<path
		d="M40 400 L140 390 L240 400 L340 370 L440 380 L540 350 L640 360 L740 340 L840 350 L940 320 L1040 330 L1140 300 L1230 310"
		stroke="#22c55e"
		stroke-width="1.6"
		fill="none"
		stroke-linecap="round"
		stroke-linejoin="round"
		opacity="0.9"
	/>

	<!-- table card -->
	<rect x="22" y="508" width="1236" height="260" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="40" y="536" fill="#f2f2f2" font-family={font} font-size="12" font-weight="500">Results</text>
	<text x="100" y="536" fill="#8a8a8a" font-family={font} font-size="11">12 series · sorted by rate</text>

	<!-- header -->
	<text x="40" y="568" fill="#8a8a8a" font-family={mono} font-size="10">SERVICE</text>
	<text x="280" y="568" fill="#8a8a8a" font-family={mono} font-size="10">OPERATION</text>
	<text x="620" y="568" fill="#8a8a8a" font-family={mono} font-size="10">RATE</text>
	<text x="780" y="568" fill="#8a8a8a" font-family={mono} font-size="10">ERROR %</text>
	<text x="960" y="568" fill="#8a8a8a" font-family={mono} font-size="10">P95</text>
	<rect x="40" y="578" width="1200" height="1" fill="#333" />

	{
		[
			{ s: "web", o: "GET /api/checkout", r: "42.1/s", e: "0.2%", p: "118ms", y: 608 },
			{ s: "web", o: "POST /api/orders", r: "18.4/s", e: "0.8%", p: "204ms", y: 648 },
			{ s: "worker", o: "jobs.process", r: "9.2/s", e: "0.0%", p: "86ms", y: 688 },
			{ s: "web", o: "GET /health", r: "4.1/s", e: "0.0%", p: "12ms", y: 728 },
		].map((row) => (
			<>
				<text x="40" y={row.y} fill="#f2f2f2" font-family={font} font-size="12" font-weight="500">
					{row.s}
				</text>
				<text x="280" y={row.y} fill="#b0b0b0" font-family={mono} font-size="12">
					{row.o}
				</text>
				<text x="620" y={row.y} fill="#f2f2f2" font-family={mono} font-size="12">
					{row.r}
				</text>
				<text x="780" y={row.y} fill="#b0b0b0" font-family={mono} font-size="12">
					{row.e}
				</text>
				<text x="960" y={row.y} fill="#b0b0b0" font-family={mono} font-size="12">
					{row.p}
				</text>
			</>
		))
	}
</svg>
