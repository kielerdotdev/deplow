---
const mono = "IBM Plex Mono, ui-monospace, monospace"
const font = "DM Sans, system-ui, sans-serif"
---

<svg viewBox="0 0 480 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Four layers: control plane, data plane, build, runtime">
	<rect width="480" height="300" fill="#000000" />

	{
		[
			{ y: 28, t: "control plane", d: "tanstack · oRPC · sqlite", n: "project metadata" },
			{ y: 94, t: "data plane", d: "postgres · redis · s3", n: "project namespace on k3s" },
			{ y: 160, t: "build", d: "railpack · dockerfile · registry", n: "BuildKit on control plane" },
			{ y: 226, t: "runtime", d: "k3s · gVisor · traefik", n: "user apps sandboxed" },
		].map((row) => (
			<>
				<rect x="32" y={row.y} width="416" height="56" rx="4" fill="#121212" stroke="#333" />
				<rect x="32" y={row.y} width="4" height="56" rx="1" fill="#f2f2f2" opacity="0.85" />
				<text x="56" y={row.y + 26} fill="#f2f2f2" font-family={font} font-size="14" font-weight="500">
					{row.t}
				</text>
				<text x="190" y={row.y + 26} fill="#8a8a8a" font-family={mono} font-size="12">
					{row.d}
				</text>
				<text x="56" y={row.y + 44} fill="#525252" font-family={mono} font-size="11">
					{row.n}
				</text>
			</>
		))
	}
</svg>
