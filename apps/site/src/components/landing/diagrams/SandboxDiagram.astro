---
const mono = "IBM Plex Mono, ui-monospace, monospace"
const font = "DM Sans, system-ui, sans-serif"
---

<svg
	viewBox="0 0 560 420"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	role="img"
	aria-label="User apps isolated under gVisor on a k3s node, separated from platform services"
>
	<rect width="560" height="420" fill="#000000" />
	<rect x="28" y="28" width="504" height="364" rx="8" fill="#121212" stroke="#333" />
	<text x="52" y="56" fill="#8a8a8a" font-family={mono} font-size="11" font-weight="500" letter-spacing="1.5">K3S NODE</text>

	<!-- user apps zone -->
	<rect x="48" y="72" width="464" height="100" rx="6" fill="#1c1c1c" stroke="#333" />
	<text x="68" y="100" fill="#f2f2f2" font-family={font} font-size="13" font-weight="500">User apps</text>
	<text x="68" y="122" fill="#8a8a8a" font-family={mono} font-size="12">web · worker · gVisor RuntimeClass</text>
	<text x="68" y="146" fill="#525252" font-family={font} font-size="11">Hardened pods · NetworkPolicy · no docker.sock</text>

	<!-- gVisor boundary -->
	<rect x="48" y="190" width="464" height="36" rx="4" fill="#242424" stroke="#333" />
	<text x="68" y="212" fill="#f2f2f2" font-family={mono} font-size="12" font-weight="500">gVisor (runsc) · syscall sandbox</text>

	<!-- platform zone -->
	<rect x="48" y="244" width="464" height="120" rx="6" fill="#0a0a0a" stroke="#2e2e2e" />
	<text x="68" y="272" fill="#f2f2f2" font-family={font} font-size="13" font-weight="500">Default runtime</text>
	<text x="68" y="296" fill="#8a8a8a" font-family={mono} font-size="12">postgres · redis · Traefik</text>
	<text x="68" y="320" fill="#525252" font-family={font} font-size="11">Data plane + ingress stay on runc/containerd</text>
	<text x="68" y="344" fill="#525252" font-family={font} font-size="11">Not MicroVMs · operator patches nodes</text>
</svg>
