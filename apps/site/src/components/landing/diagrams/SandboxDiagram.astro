<svg
	viewBox="0 0 560 420"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	role="img"
	aria-label="User apps isolated under gVisor on a k3s node, separated from platform services"
>
	<defs>
		<linearGradient id="sb-sage" x1="0" y1="0" x2="0" y2="1">
			<stop stop-color="#5eead4" />
			<stop offset="1" stop-color="#2dd4bf" />
		</linearGradient>
	</defs>

	<rect width="560" height="420" fill="#07091a" />

	<!-- host boundary -->
	<rect x="28" y="28" width="504" height="364" rx="16" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" />
	<text x="52" y="56" fill="#4d5480" font-family="IBM Plex Mono, monospace" font-size="11" font-weight="500" letter-spacing="2">K3S NODE</text>

	<!-- gVisor wall -->
	<rect x="28" y="164" width="504" height="2" fill="#fb7185" opacity="0.5" />
	<rect x="28" y="172" width="504" height="50" rx="10" fill="rgba(251,113,133,0.06)" stroke="rgba(251,113,133,0.18)" />
	<text x="60" y="198" fill="#fb7185" font-family="IBM Plex Mono, monospace" font-size="13" font-weight="600">gVisor kernel (runsc)</text>
	<rect x="244" y="184" width="92" height="22" rx="6" fill="rgba(251,113,133,0.12)" />
	<text x="290" y="199" fill="#fb7185" font-family="IBM Plex Sans, sans-serif" font-size="10" font-weight="700" text-anchor="middle">syscall gate</text>
	<rect x="346" y="184" width="86" height="22" rx="6" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.07)" />
	<text x="389" y="199" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="9" text-anchor="middle">ptrace blocked</text>
	<rect x="440" y="184" width="78" height="22" rx="6" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.07)" />
	<text x="479" y="199" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="9" text-anchor="middle">/proc masked</text>

	<!-- platform services (top half — runc) -->
	<text x="52" y="86" fill="#5eead4" font-family="IBM Plex Mono, monospace" font-size="10" font-weight="500" letter-spacing="1.5">PLATFORM · runc (trusted)</text>

	<rect x="52" y="100" width="142" height="48" rx="9" fill="rgba(94,234,212,0.05)" stroke="rgba(94,234,212,0.18)" />
	<rect x="52" y="100" width="4" height="48" rx="2" fill="url(#sb-sage)" />
	<text x="72" y="122" fill="#eef1fb" font-family="IBM Plex Mono, monospace" font-size="12" font-weight="600">traefik</text>
	<text x="72" y="138" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="9">ingress · kube-system</text>

	<rect x="206" y="100" width="100" height="48" rx="9" fill="rgba(94,234,212,0.05)" stroke="rgba(94,234,212,0.18)" />
	<rect x="206" y="100" width="4" height="48" rx="2" fill="url(#sb-sage)" />
	<text x="226" y="122" fill="#eef1fb" font-family="IBM Plex Mono, monospace" font-size="12" font-weight="600">postgres</text>
	<text x="226" y="138" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="9">pg17 · idle</text>

	<rect x="318" y="100" width="100" height="48" rx="9" fill="rgba(94,234,212,0.05)" stroke="rgba(94,234,212,0.18)" />
	<rect x="318" y="100" width="4" height="48" rx="2" fill="url(#sb-sage)" />
	<text x="338" y="122" fill="#eef1fb" font-family="IBM Plex Mono, monospace" font-size="12" font-weight="600">redis</text>
	<text x="338" y="138" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="9">:6379</text>

	<rect x="430" y="100" width="84" height="48" rx="9" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.08)" />
	<rect x="430" y="100" width="4" height="48" rx="2" fill="url(#sb-sage)" />
	<text x="450" y="122" fill="#c7cce0" font-family="IBM Plex Mono, monospace" font-size="12" font-weight="600">minio</text>
	<text x="450" y="138" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="9">s3</text>

	<!-- user apps (bottom half — gVisor sandboxed) -->
	<text x="52" y="252" fill="#fb7185" font-family="IBM Plex Mono, monospace" font-size="10" font-weight="500" letter-spacing="1.5">USER APPS · gVisor (untrusted)</text>

	<rect x="52" y="266" width="118" height="56" rx="9" fill="rgba(251,113,133,0.04)" stroke="rgba(251,113,133,0.18)" stroke-dasharray="4 4" />
	<text x="111" y="288" fill="#eef1fb" font-family="IBM Plex Mono, monospace" font-size="12" font-weight="600" text-anchor="middle">web</text>
	<rect x="84" y="298" width="54" height="14" rx="7" fill="rgba(251,113,133,0.14)" />
	<text x="111" y="309" fill="#fb7185" font-family="IBM Plex Sans, sans-serif" font-size="8" font-weight="700" text-anchor="middle">SANDBOX</text>

	<rect x="184" y="266" width="118" height="56" rx="9" fill="rgba(251,113,133,0.04)" stroke="rgba(251,113,133,0.18)" stroke-dasharray="4 4" />
	<text x="243" y="288" fill="#eef1fb" font-family="IBM Plex Mono, monospace" font-size="12" font-weight="600" text-anchor="middle">worker</text>
	<rect x="216" y="298" width="54" height="14" rx="7" fill="rgba(251,113,133,0.14)" />
	<text x="243" y="309" fill="#fb7185" font-family="IBM Plex Sans, sans-serif" font-size="8" font-weight="700" text-anchor="middle">SANDBOX</text>


	<!-- arrow: app syscall blocked at the gVisor wall -->
	<path d="M111 244v-12" stroke="#fb7185" stroke-width="1.5" stroke-linecap="round" />
	<path d="M111 232l-3 3M111 232l3 3" stroke="#fb7185" stroke-width="1.5" stroke-linecap="round" opacity="0.6" />

	<!-- footer hint -->
	<rect x="52" y="346" width="456" height="32" rx="9" fill="rgba(94,234,212,0.03)" stroke="rgba(94,234,212,0.14)" />
	<circle cx="74" cy="362" r="4" fill="#5eead4" />
	<text x="88" y="365" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="10">platform sees the host — user apps see a</text>
	<text x="402" y="365" fill="#5eead4" font-family="IBM Plex Mono, monospace" font-size="10" font-weight="600">forged kernel</text>
	<text x="466" y="365" fill="#888fa8" font-family="IBM Plex Mono, monospace" font-size="10">.</text>
</svg>