---
/** Compact stack diagram — dark Atlasflow tokens */
const font = "DM Sans, system-ui, sans-serif"
const mono = "IBM Plex Mono, ui-monospace, monospace"
---

<svg viewBox="0 0 720 320" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="App connected to postgres, redis, and object storage on k3s with gVisor">
	<rect width="720" height="320" fill="#000000" />
	<rect x="48" y="28" width="624" height="264" rx="8" fill="#121212" stroke="#333333" />

	<!-- services -->
	<rect x="156" y="52" width="120" height="36" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="216" y="74" fill="#f2f2f2" font-family={mono} font-size="12" font-weight="500" text-anchor="middle">postgres</text>

	<rect x="300" y="52" width="120" height="36" rx="4" fill="#1c1c1c" stroke="#333" />
	<circle cx="324" cy="70" r="4" fill="#22c55e" />
	<text x="360" y="74" fill="#f2f2f2" font-family={mono} font-size="12" font-weight="500" text-anchor="middle">redis</text>

	<rect x="444" y="52" width="120" height="36" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="504" y="74" fill="#f2f2f2" font-family={mono} font-size="12" font-weight="500" text-anchor="middle">s3</text>

	<path d="M216 88v24M360 88v24M504 88v24" stroke="#333" stroke-width="1.5" stroke-dasharray="3 4" stroke-linecap="round" />

	<!-- host -->
	<rect x="120" y="112" width="480" height="148" rx="6" fill="#0a0a0a" stroke="#2e2e2e" />
	<text x="140" y="138" fill="#8a8a8a" font-family={mono} font-size="11" letter-spacing="1.2">K3S · GVISOR</text>

	<rect x="160" y="158" width="160" height="72" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="240" y="190" fill="#f2f2f2" font-family={font} font-size="14" font-weight="500" text-anchor="middle">web</text>
	<text x="240" y="210" fill="#8a8a8a" font-family={mono} font-size="11" text-anchor="middle">RuntimeClass gvisor</text>

	<rect x="400" y="158" width="160" height="72" rx="4" fill="#1c1c1c" stroke="#333" />
	<text x="480" y="190" fill="#f2f2f2" font-family={font} font-size="14" font-weight="500" text-anchor="middle">worker</text>
	<text x="480" y="210" fill="#8a8a8a" font-family={mono} font-size="11" text-anchor="middle">private</text>

	<text x="140" y="250" fill="#525252" font-family={font} font-size="11">Traefik ingress · edge TLS · bindings inject DATABASE_URL / REDIS_URL</text>
</svg>
