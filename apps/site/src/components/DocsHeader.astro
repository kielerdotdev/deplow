---
import Default from '@astrojs/starlight/components/Header.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3000';
---

<div class="docs-header-wrap">
	<Default {...Astro.props}>
		<slot />
	</Default>
	<div class="docs-header-actions">
		<a class="docs-header-link" href="/">Home</a>
		<a class="docs-header-link docs-header-cta" href={appUrl}>Dashboard →</a>
	</div>
</div>

<style>
	.docs-header-wrap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
	}

	.docs-header-actions {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		margin-inline-start: auto;
		padding-inline-end: 0.5rem;
	}

	.docs-header-link {
		padding: 0.35rem 0.7rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--sl-color-gray-3);
		border-radius: 999px;
		text-decoration: none;
		white-space: nowrap;
	}

	.docs-header-link:hover {
		color: var(--sl-color-text);
	}

	.docs-header-cta {
		color: #fbf8f3;
		background: #1c2333;
	}

	.docs-header-cta:hover {
		color: #fbf8f3;
		background: #2a3347;
	}

	@media (max-width: 50rem) {
		.docs-header-actions .docs-header-link:not(.docs-header-cta) {
			display: none;
		}
	}
</style>