---
import Default from '@astrojs/starlight/components/Header.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'https://deplow.waitforit.cc';
---

<div class="docs-header-wrap">
	<Default {...Astro.props}>
		<slot />
	</Default>
	<div class="docs-header-actions">
		<a class="docs-header-link" href="/">Home</a>
		<a class="docs-header-link docs-header-cta" href={appUrl}>Open app</a>
	</div>
</div>

<style>
	.docs-header-wrap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		width: 100%;
		min-width: 0;
	}

	.docs-header-wrap :global(.header) {
		min-width: 0;
		flex: 1 1 auto;
	}

	.docs-header-actions {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		flex-shrink: 0;
		margin-inline-start: auto;
		padding-inline-end: 0.75rem;
	}

	.docs-header-link {
		padding: 0.35rem 0.7rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--sl-color-gray-3, #707070);
		border-radius: 4px;
		text-decoration: none;
		white-space: nowrap;
		transition:
			color 0.15s ease,
			background 0.15s ease;
	}

	.docs-header-link:hover {
		color: var(--sl-color-white, #fafafa);
		background: rgba(255, 255, 255, 0.04);
	}

	.docs-header-cta {
		color: #0a0a0a !important;
		background: #fafafa;
		border: 1px solid transparent;
		border-radius: 4px;
		font-weight: 600;
	}

	.docs-header-cta:hover {
		background: #e4e4e7 !important;
		color: #0a0a0a !important;
	}

	@media (max-width: 50rem) {
		.docs-header-actions .docs-header-link:not(.docs-header-cta) {
			display: none;
		}
	}
</style>
