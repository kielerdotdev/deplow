---
import Default from '@astrojs/starlight/components/Header.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3000';
---

<div class="docs-header-wrap">
	<Default {...Astro.props}>
		<slot />
	</Default>
	<div class="docs-header-actions">
		<a class="docs-header-link" href="/">Home</a>
		<a class="docs-header-link docs-header-cta" href={appUrl}>Dashboard →</a>
	</div>
</div>

<style>
	.docs-header-wrap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
		min-width: 0;
	}

	.docs-header-wrap :global(.header) {
		min-width: 0;
		flex: 1 1 auto;
	}

	.docs-header-actions {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		flex-shrink: 0;
		margin-inline-start: auto;
		padding-inline-end: 0.5rem;
	}

	.docs-header-link {
		padding: 0.4rem 0.75rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--sl-color-gray-3);
		border-radius: 6px;
		text-decoration: none;
		white-space: nowrap;
	}

	.docs-header-link:hover {
		color: var(--sl-color-white);
	}

	.docs-header-cta {
		color: #09090b !important;
		background: #fafafa;
		border: 1px solid transparent;
		border-radius: 999px;
		font-weight: 600;
	}

	.docs-header-cta:hover {
		background: #e4e4e7;
	}

	@media (max-width: 50rem) {
		.docs-header-actions .docs-header-link:not(.docs-header-cta) {
			display: none;
		}
	}
</style>
